{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "svelte-tauri-template",
  "identifier": "com.plures.svelte-tauri-template",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "svelte-tauri-template",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost 'self'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'"
      }
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/128x128.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

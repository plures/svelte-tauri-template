{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "main window — least privilege for events-not-commands bridge",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:tray:default",
    "core:menu:default",
    "shell:default"
  ]
}
